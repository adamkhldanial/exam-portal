models:
    User: { role: 'enum:lecturer,student default:student' }
    ClassRoom: { name: string, code: 'string unique', description: 'text nullable', created_by: 'id foreign:users onDelete:cascade' }
    ClassStudent: { table: class_student, class_room_id: 'id foreign:class_rooms onDelete:cascade', user_id: 'id foreign:users onDelete:cascade' }
    Subject: { name: string, code: 'string unique', description: 'text nullable', class_room_id: 'id foreign:class_rooms onDelete:cascade', created_by: 'id foreign:users onDelete:cascade' }
    Exam: { title: string, description: 'text nullable', subject_id: 'id foreign:subjects onDelete:cascade', created_by: 'id foreign:users onDelete:cascade', time_limit: unsignedInteger, starts_at: 'timestamp nullable', ends_at: 'timestamp nullable', is_published: 'boolean default:false', passing_score: 'unsignedInteger default:50' }
    Question: { exam_id: 'id foreign:exams onDelete:cascade', question_text: text, type: 'enum:multiple_choice,open_text', marks: 'unsignedInteger default:1', order: 'unsignedInteger default:0' }
    Option: { question_id: 'id foreign:questions onDelete:cascade', option_text: string, is_correct: 'boolean default:false' }
    ExamSubmission: { exam_id: 'id foreign:exams onDelete:cascade', user_id: 'id foreign:users onDelete:cascade', started_at: timestamp, submitted_at: 'timestamp nullable', score: 'unsignedInteger nullable', total_marks: 'unsignedInteger nullable', status: 'enum:in_progress,submitted,graded default:in_progress' }
    Answer: { exam_submission_id: 'id foreign:exam_submissions onDelete:cascade', question_id: 'id foreign:questions onDelete:cascade', option_id: 'id foreign:options nullable onDelete:null', answer_text: 'text nullable', marks_awarded: 'unsignedInteger nullable' }
